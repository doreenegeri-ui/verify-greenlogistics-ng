-- documents.sql - Database schema for Green Transport & Logistics

-- Documents table
CREATE TABLE documents (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    reference_number VARCHAR(50) UNIQUE NOT NULL,
    document_type VARCHAR(100) NOT NULL,
    client_name VARCHAR(255),
    issue_date DATE NOT NULL,
    expiry_date DATE,
    status VARCHAR(20) DEFAULT 'valid' CHECK(status IN ('valid', 'expired', 'revoked')),
    revocation_reason TEXT,
    notes TEXT,
    qr_code_data TEXT,
    created_by VARCHAR(100) NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    last_modified TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    is_deleted BOOLEAN DEFAULT FALSE
);

-- Verification logs table
CREATE TABLE verification_logs (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    document_id INTEGER,
    reference_number VARCHAR(50) NOT NULL,
    verification_time TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    ip_address VARCHAR(45),
    user_agent TEXT,
    browser_type VARCHAR(100),
    device_type VARCHAR(50),
    verification_status VARCHAR(20),
    FOREIGN KEY (document_id) REFERENCES documents(id)
);

-- Admin users table
CREATE TABLE admin_users (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    username VARCHAR(100) UNIQUE NOT NULL,
    password_hash VARCHAR(255) NOT NULL,
    email VARCHAR(255) UNIQUE NOT NULL,
    full_name VARCHAR(255) NOT NULL,
    role VARCHAR(50) DEFAULT 'admin',
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    last_login TIMESTAMP
);

-- Rate limiting table
CREATE TABLE rate_limits (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    identifier VARCHAR(255) NOT NULL,
    request_count INTEGER DEFAULT 1,
    first_request TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    last_request TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Indexes for performance
CREATE INDEX idx_documents_reference ON documents(reference_number);
CREATE INDEX idx_documents_status ON documents(status);
CREATE INDEX idx_verification_logs_doc_id ON verification_logs(document_id);
CREATE INDEX idx_verification_logs_time ON verification_logs(verification_time);
CREATE INDEX idx_rate_limits_identifier ON rate_limits(identifier);

// server/app.js - Main application entry point
const express = require('express');
const cors = require('cors');
const helmet = require('helmet');
const rateLimit = require('express-rate-limit');
const validator = require('validator');
const path = require('path');
const { initDatabase } = require('./utils/database');
const documentRoutes = require('./routes/documents');
const adminRoutes = require('./routes/admin');
const { logVerification } = require('./middleware/logging');

const app = express();
const PORT = process.env.PORT || 3000;

// Security middleware
app.use(helmet({
    contentSecurityPolicy: {
        directives: {
            defaultSrc: ["'self'"],
            styleSrc: ["'self'", "'unsafe-inline'"],
            scriptSrc: ["'self'"],
            imgSrc: ["'self'", 'data:', 'https:']
        }
    }
}));

// CORS configuration
app.use(cors({
    origin: process.env.ALLOWED_ORIGINS?.split(',') || ['https://www.greenlogistics-ng.com'],
    credentials: true
}));

// Rate limiting - 100 requests per 15 minutes per IP
const limiter = rateLimit({
    windowMs: 15 * 60 * 1000,
    max: 100,
    message: 'Too many requests from this IP, please try again later.',
    standardHeaders: true
});
app.use('/api/', limiter);

// Stricter rate limit for verification endpoint
const verifyLimiter = rateLimit({
    windowMs: 15 * 60 * 1000,
    max: 30,
    message: 'Too many verification attempts, please try again later.',
    keyGenerator: (req) => req.ip + '-verify'
});

// Body parsing
app.use(express.json({ limit: '10kb' }));
app.use(express.urlencoded({ extended: true, limit: '10kb' }));

// Input sanitization middleware
app.use((req, res, next) => {
    // Sanitize all string inputs
    const sanitize = (obj) => {
        if (typeof obj === 'string') {
            return validator.escape(obj.trim());
        }
        if (Array.isArray(obj)) {
            return obj.map(sanitize);
        }
        if (obj && typeof obj === 'object') {
            Object.keys(obj).forEach(key => {
                obj[key] = sanitize(obj[key]);
            });
        }
        return obj;
    };
    
    if (req.body) req.body = sanitize(req.body);
    if (req.query) req.query = sanitize(req.query);
    if (req.params) req.params = sanitize(req.params);
    
    next();
});

// Static files
app.use(express.static(path.join(__dirname, '../public')));
app.use('/admin', express.static(path.join(__dirname, '../admin')));

// Routes
app.use('/api/documents', verifyLimiter, logVerification, documentRoutes);
app.use('/api/admin', adminRoutes);

// Public verification page
app.get('/verify', (req, res) => {
    res.sendFile(path.join(__dirname, '../public/verify.html'));
});

// Verification with reference in URL
app.get('/verify/:reference', (req, res) => {
    res.sendFile(path.join(__dirname, '../public/verify.html'));
});

// Initialize database and start server
initDatabase()
    .then(() => {
        app.listen(PORT, () => {
            console.log(`Server running on port ${PORT}`);
            console.log(`Verification page: https://www.greenlogistics-ng.com/verify`);
            console.log(`Admin dashboard: https://www.greenlogistics-ng.com/admin`);
        });
    })
    .catch(err => {
        console.error('Database initialization failed:', err);
        process.exit(1);
    });

module.exports = app;
// server/routes/documents.js - Document verification API
const express = require('express');
const router = express.Router();
const db = require('../utils/database');
const { validateReference } = require('../utils/validators');

// Verify document by reference number
router.get('/verify/:reference?', async (req, res) => {
    try {
        const reference = req.params.reference || req.query.ref;
        
        if (!reference) {
            return res.status(400).json({
                success: false,
                message: 'Document reference number required'
            });
        }
        
        // Validate reference format
        const validation = validateReference(reference);
        if (!validation.valid) {
            return res.status(400).json({
                success: false,
                message: validation.message
            });
        }
        
        // Query database using parameterized query
        const document = await db.get(`
            SELECT 
                id,
                reference_number,
                document_type,
                client_name,
                issue_date,
                expiry_date,
                status,
                revocation_reason,
                created_at,
                last_modified
            FROM documents
            WHERE reference_number = ? AND is_deleted = 0
        `, [reference]);
        
        if (!document) {
            return res.status(404).json({
                success: false,
                message: 'Document not found',
                verified: false
            });
        }
        
        // Check if expired
        let status = document.status;
        if (status === 'valid' && document.expiry_date) {
            const expiryDate = new Date(document.expiry_date);
            if (expiryDate < new Date()) {
                status = 'expired';
            }
        }
        
        res.json({
            success: true,
            verified: true,
            document: {
                referenceNumber: document.reference_number,
                documentType: document.document_type,
                clientName: document.client_name,
                issueDate: document.issue_date,
                expiryDate: document.expiry_date,
                status: status,
                revocationReason: document.revocation_reason,
                qrGeneratedOn: document.created_at,
                lastUpdated: document.last_modified,
                issuedBy: 'Green Transport & Logistics'
            }
        });
        
    } catch (error) {
        console.error('Verification error:', error);
        res.status(500).json({
            success: false,
            message: 'Verification service temporarily unavailable'
        });
    }
});

// Get document analytics (admin only)
router.get('/analytics', async (req, res) => {
    try {
        const [
            totalDocuments,
            totalVerifications,
            invalidAttempts,
            recentVerifications
        ] = await Promise.all([
            db.get(`SELECT COUNT(*) as count FROM documents WHERE is_deleted = 0`),
            db.get(`SELECT COUNT(*) as count FROM verification_logs`),
            db.get(`SELECT COUNT(*) as count FROM verification_logs WHERE verification_status = 'not_found'`),
            db.all(`
                SELECT 
                    vl.reference_number,
                    vl.verification_time,
                    vl.verification_status,
                    d.document_type
                FROM verification_logs vl
                LEFT JOIN documents d ON vl.document_id = d.id
                ORDER BY vl.verification_time DESC
                LIMIT 50
            `)
        ]);
        
        res.json({
            success: true,
            analytics: {
                totalDocuments: totalDocuments.count,
                totalVerifications: totalVerifications.count,
                invalidAttempts: invalidAttempts.count,
                recentVerifications: recentVerifications
            }
        });
        
    } catch (error) {
        console.error('Analytics error:', error);
        res.status(500).json({
            success: false,
            message: 'Failed to retrieve analytics'
        });
    }
});

module.exports = router;

