/**
 * Client-Side Database for Document Verification System
 * Uses localStorage for demo purposes
 * For production: Replace with backend API calls
 */

const DB_KEYS = {
    DOCUMENTS: 'gtl_documents',
    VERIFICATION_LOGS: 'gtl_verification_logs',
    USERS: 'gtl_admin_users'
};

// Initialize default admin user
function initializeDefaultUser() {
    const users = getUsers();
    if (users.length === 0) {
        const defaultUser = {
            id: 1,
            username: 'admin',
            password: 'admin123', // Change this immediately
            email: 'admin@greenlogistics-ng.com',
            fullName: 'Admin User',
            role: 'admin',
            isActive: true,
            createdAt: new Date().toISOString(),
            lastLogin: null
        };
        users.push(defaultUser);
        localStorage.setItem(DB_KEYS.USERS, JSON.stringify(users));
        console.log('Default admin user created. Please change password immediately.');
    }
}

// Documents Functions
function getDocuments() {
    const docs = localStorage.getItem(DB_KEYS.DOCUMENTS);
    return docs ? JSON.parse(docs) : [];
}

function saveDocuments(documents) {
    localStorage.setItem(DB_KEYS.DOCUMENTS, JSON.stringify(documents));
}

function addDocument(document) {
    const documents = getDocuments();
    const existing = documents.find(doc => doc.referenceNumber === document.referenceNumber);
    
    if (existing) {
        throw new Error('Document reference number already exists');
    }
    
    const newDoc = {
        id: Date.now(),
        ...document,
        status: 'valid',
        revocationReason: null,
        qrCodeData: `https://www.greenlogistics-ng.com/verify/${document.referenceNumber}`,
        createdAt: new Date().toISOString(),
        lastModified: new Date().toISOString()
    };
    
    documents.push(newDoc);
    saveDocuments(documents);
    return newDoc;
}

function updateDocument(id, updates) {
    const documents = getDocuments();
    const index = documents.findIndex(doc => doc.id === id);
    
    if (index === -1) {
        throw new Error('Document not found');
    }
    
    documents[index] = {
        ...documents[index],
        ...updates,
        lastModified: new Date().toISOString()
    };
    
    saveDocuments(documents);
    return documents[index];
}

function deleteDocument(id) {
    const documents = getDocuments();
    const filtered = documents.filter(doc => doc.id !== id);
    saveDocuments(filtered);
}

function getDocumentByReference(reference) {
    const documents = getDocuments();
    return documents.find(doc => doc.referenceNumber === reference);
}

// Verification Logs Functions
function getVerificationLogs() {
    const logs = localStorage.getItem(DB_KEYS.VERIFICATION_LOGS);
    return logs ? JSON.parse(logs) : [];
}

function saveLogs(logs) {
    localStorage.setItem(DB_KEYS.VERIFICATION_LOGS, JSON.stringify(logs));
}

function addVerificationLog(log) {
    const logs = getVerificationLogs();
    const newLog = {
        id: Date.now(),
        ...log,
        timestamp: new Date().toISOString()
    };
    
    logs.unshift(newLog); // Add to beginning
    
    // Keep only last 1000 logs
    if (logs.length > 1000) {
        logs.length = 1000;
    }
    
    saveLogs(logs);
    return newLog;
}

// Users Functions
function getUsers() {
    const users = localStorage.getItem(DB_KEYS.USERS);
    return users ? JSON.parse(users) : [];
}

function saveUsers(users) {
    localStorage.setItem(DB_KEYS.USERS, JSON.stringify(users));
}

function authenticateUser(username, password) {
    const users = getUsers();
    const user = users.find(u => u.username === username && u.password === password && u.isActive);
    
    if (user) {
        user.lastLogin = new Date().toISOString();
        saveUsers(users);
        return { ...user, password: undefined }; // Don't return password
    }
    
    return null;
}

// Analytics Functions
function getAnalytics() {
    const documents = getDocuments();
    const logs = getVerificationLogs();
    
    const totalDocuments = documents.length;
    const totalVerifications = logs.length;
    const invalidAttempts = logs.filter(log => log.status === 'not_found').length;
    const successRate = totalVerifications > 0 
        ? Math.round(((totalVerifications - invalidAttempts) / totalVerifications) * 100) 
        : 0;
    
    return {
        totalDocuments,
        totalVerifications,
        invalidAttempts,
        successRate,
        recentVerifications: logs.slice(0, 50)
    };
}

// Utility Functions
function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

function formatDate(dateString) {
    if (!dateString) return 'N/A';
    const date = new Date(dateString);
    return date.toLocaleDateString('en-NG', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
    });
}

// Initialize on load
initializeDefaultUser();

// Export for use in other scripts
if (typeof window !== 'undefined') {
    window.Database = {
        getDocuments,
        saveDocuments,
        addDocument,
        updateDocument,
        deleteDocument,
        getDocumentByReference,
        getVerificationLogs,
        addVerificationLog,
        getUsers,
        saveUsers,
        authenticateUser,
        getAnalytics,
        escapeHtml,
        formatDate
    };
}

/**
 * Document Verification System - Main Script
 * For production: Replace localStorage calls with API calls
 */

document.addEventListener('DOMContentLoaded', function() {
    const referenceInput = document.getElementById('referenceInput');
    const verifyBtn = document.getElementById('verifyBtn');
    const resultsSection = document.getElementById('resultsSection');
    const btnText = verifyBtn.querySelector('.btn-text');
    const btnLoader = verifyBtn.querySelector('.btn-loader');
    
    // Show demo mode notice
    const demoNote = document.querySelector('.demo-note');
    if (demoNote && !localStorage.getItem('gtl_documents')) {
        demoNote.style.display = 'block';
    }
    
    // Check URL for reference parameter
    checkUrlForReference();
    
    // Verify button click handler
    verifyBtn.addEventListener('click', verifyDocument);
    
    // Enter key handler
    referenceInput.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            verifyDocument();
        }
    });
    
    // Input validation - only allow alphanumeric and hyphens
    referenceInput.addEventListener('input', function(e) {
        const value = e.target.value;
        const sanitized = value.replace(/[^a-zA-Z0-9-]/g, '');
        if (value !== sanitized) {
            e.target.value = sanitized;
        }
    });
    
    function checkUrlForReference() {
        const path = window.location.pathname;
        const urlParams = new URLSearchParams(window.location.search);
        
        // Check path format: /verify/GTL-QT-2026-00125
        const pathParts = path.split('/');
        if (pathParts.length >= 2 && pathParts[pathParts.length - 1]) {
            const refFromPath = decodeURIComponent(pathParts[pathParts.length - 1]);
            if (isValidReferenceFormat(refFromPath)) {
                referenceInput.value = refFromPath;
                setTimeout(() => verifyDocument(), 500);
                return;
            }
        }
        
        // Check query parameter: /verify?ref=GTL-QT-2026-00125
        const refFromQuery = urlParams.get('ref');
        if (refFromQuery && isValidReferenceFormat(refFromQuery)) {
            referenceInput.value = refFromQuery;
            setTimeout(() => verifyDocument(), 500);
            return;
        }
    }
    
    function isValidReferenceFormat(ref) {
        // Basic validation: GTL-XX-YYYY-NNNNN format
        const pattern = /^GTL-[A-Z]{2}-\d{4}-\d{5,}$/i;
        return pattern.test(ref);
    }
    
    async function verifyDocument() {
        const reference = referenceInput.value.trim();
        
        if (!reference) {
            showError('Please enter a document reference number');
            return;
        }
        
        // Basic format validation
        if (!isValidReferenceFormat(reference)) {
            showError('Invalid reference format. Expected: GTL-XX-YYYY-NNNNN');
            return;
        }
        
        // Disable button and show loading
        setLoading(true);
        hideResults();
        
        try {
            // Get document from database
            const document = window.Database.getDocumentByReference(reference);
            
            if (!document) {
                // Log verification attempt
                window.Database.addVerificationLog({
                    referenceNumber: reference,
                    status: 'not_found',
                    documentType: null,
                    clientName: null,
                    browserType: getBrowserType(),
                    deviceType: getDeviceType()
                });
                
                showInvalid();
                return;
            }
            
            // Check if expired
            let status = document.status;
            if (status === 'valid' && document.expiryDate) {
                const expiryDate = new Date(document.expiryDate);
                if (expiryDate < new Date()) {
                    status = 'expired';
                }
            }
            
            // Log verification
            window.Database.addVerificationLog({
                referenceNumber: reference,
                status: status,
                documentType: document.documentType,
                clientName: document.clientName,
                browserType: getBrowserType(),
                deviceType: getDeviceType()
            });
            
            // Display result
            displayVerificationResult({
                ...document,
                status: status
            });
            
        } catch (error) {
            console.error('Verification error:', error);
            showError('Network error. Please check your connection and try again.');
        } finally {
            setLoading(false);
        }
    }
    
    function displayVerificationResult(doc) {
        hideResults();
        
        if (doc.status === 'revoked') {
            showRevoked(doc.revocationReason);
            return;
        }
        
        // Populate verified card
        document.getElementById('docType').textContent = doc.documentType;
        document.getElementById('docRef').textContent = doc.referenceNumber;
        document.getElementById('docIssue').textContent = formatDate(doc.issueDate);
        document.getElementById('docExpiry').textContent = doc.expiryDate ? formatDate(doc.expiryDate) : 'N/A';
        document.getElementById('docIssuedBy').textContent = 'Green Transport & Logistics';
        document.getElementById('docClient').textContent = doc.clientName || 'Confidential';
        
        const statusElement = document.getElementById('docStatus');
        statusElement.textContent = doc.status;
        statusElement.className = 'status-badge ' + doc.status;
        
        document.getElementById('docQrDate').textContent = formatDate(doc.createdAt);
        document.getElementById('docUpdated').textContent = formatDate(doc.lastModified);
        
        document.getElementById('verifiedCard').style.display = 'block';
        resultsSection.style.display = 'block';
    }
    
    function showInvalid() {
        hideResults();
        document.getElementById('invalidCard').style.display = 'block';
        resultsSection.style.display = 'block';
    }
    
    function showRevoked(reason) {
        hideResults();
        document.getElementById('revocationReason').textContent = reason || 'No reason provided';
        document.getElementById('revokedCard').style.display = 'block';
        resultsSection.style.display = 'block';
    }
    
    function showError(message) {
        hideResults();
        document.getElementById('errorMessage').textContent = message;
        document.getElementById('errorCard').style.display = 'block';
        resultsSection.style.display = 'block';
    }
    
    function hideResults() {
        resultsSection.style.display = 'none';
        document.getElementById('verifiedCard').style.display = 'none';
        document.getElementById('revokedCard').style.display = 'none';
        document.getElementById('invalidCard').style.display = 'none';
        document.getElementById('errorCard').style.display = 'none';
    }
    
    function setLoading(loading) {
        verifyBtn.disabled = loading;
        btnText.style.display = loading ? 'none' : 'inline';
        btnLoader.style.display = loading ? 'inline' : 'none';
    }
    
    function formatDate(dateString) {
        if (!dateString) return 'N/A';
        const date = new Date(dateString);
        return date.toLocaleDateString('en-NG', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
        });
    }
    
    function getBrowserType() {
        const userAgent = navigator.userAgent;
        if (userAgent.includes('Chrome')) return 'Chrome';
        if (userAgent.includes('Firefox')) return 'Firefox';
        if (userAgent.includes('Safari')) return 'Safari';
        if (userAgent.includes('Edge')) return 'Edge';
        return 'Other';
    }
    
    function getDeviceType() {
        const userAgent = navigator.userAgent;
        if (userAgent.includes('Mobile')) return 'Mobile';
        if (userAgent.includes('Tablet')) return 'Tablet';
        return 'Desktop';
    }
    
    // Expose reset function globally
    window.resetSearch = function() {
        referenceInput.value = '';
        hideResults();
        referenceInput.focus();
    };
});

