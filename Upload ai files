async function handleLogin(e) {
    e.preventDefault();
    
    const username = document.getElementById('username').value;
    const password = document.getElementById('password').value;
    const errorEl = document.getElementById('loginError');
    
    try {
        const user = window.Database.authenticateUser(username, password);
        
        if (!user) {
            errorEl.textContent = 'Invalid username or password';
            errorEl.style.display = 'block';
            return;
        }
        
        currentUser = user;
        localStorage.setItem('gtl_currentUser', JSON.stringify(user));
        
        document.getElementById('loginPage').style.display = 'none';
        document.getElementById('dashboardPage').style.display = 'flex';
        
        loadDashboard();
        
    } catch (error) {
        console.error('Login error:', error);
        errorEl.textContent = 'Login failed. Please try again.';
        errorEl.style.display = 'block';
    }
}

function handleLogout() {
    currentUser = null;
    localStorage.removeItem('gtl_currentUser');
    document.getElementById('dashboardPage').style.display = 'none';
    document.getElementById('loginPage').style.display = 'flex';
    document.getElementById('loginForm').reset();
}

function loadDashboard() {
    document.getElementById('loginPage').style.display = 'none';
    document.getElementById('dashboardPage').style.display = 'flex';
    
    if (currentUser) {
        document.getElementById('userFullName').textContent = currentUser.fullName;
        document.getElementById('userRole').textContent = currentUser.role;
    }
    
    loadAnalytics();
    loadDocuments();
    loadHistory();
    showPage('overview');
}

function loadAnalytics() {
    const analytics = window.Database.getAnalytics();
    
    document.getElementById('totalDocuments').textContent = analytics.totalDocuments;
    document.getElementById('totalVerifications').textContent = analytics.totalVerifications;
    document.getElementById('invalidAttempts').textContent = analytics.invalidAttempts;
    document.getElementById('successRate').textContent = analytics.successRate + '%';
    
    // Populate recent verifications table
    const tbody = document.querySelector('#recentTable tbody');
    tbody.innerHTML = analytics.recentVerifications.slice(0, 10).map(log => `
        <tr>
            <td>${window.Database.escapeHtml(log.referenceNumber)}</td>
            <td>${window.Database.escapeHtml(log.documentType || 'N/A')}</td>
            <td><span class="status-badge ${log.status}">${log.status}</span></td>
            <td>${window.Database.formatDate(log.timestamp)}</td>
        </tr>
    `).join('');
}

function loadDocuments() {
    const search = document.getElementById('searchInput')?.value || '';
    const status = document.getElementById('statusFilter')?.value || '';
    
    let documents = window.Database.getDocuments();
    
    // Filter by search
    if (search) {
        const searchTerm = search.toLowerCase();
        documents = documents.filter(doc => 
            doc.referenceNumber.toLowerCase().includes(searchTerm) ||
            (doc.clientName && doc.clientName.toLowerCase().includes(searchTerm)) ||
            doc.documentType.toLowerCase().includes(searchTerm)
        );
    }
    
    // Filter by status
    if (status) {
        documents = documents.filter(doc => doc.status === status);
    }
    
    // Populate table
    const tbody = document.querySelector('#documentsTable tbody');
    tbody.innerHTML = documents.map(doc => `
        <tr>
            <td>${window.Database.escapeHtml(doc.referenceNumber)}</td>
            <td>${window.Database.escapeHtml(doc.documentType)}</td>
            <td>${window.Database.escapeHtml(doc.clientName || 'N/A')}</td>
            <td>${window.Database.formatDate(doc.issueDate)}</td>
            <td><span class="status-badge ${doc.status}">${doc.status}</span></td>
            <td>
                <button class="action-btn edit-btn" onclick="editDocument(${doc.id})">Edit</button>
                <button class="action-btn revoke-btn" onclick="revokeDocument(${doc.id})">Revoke</button>
                <button class="action-btn delete-btn" onclick="deleteDocument(${doc.id})">Delete</button>
            </td>
        </tr>
    `).join('');
}

function handleAddDocument(e) {
    e.preventDefault();
    
    const document = {
        referenceNumber: document.getElementById('refNumber').value.trim(),
        documentType: document.getElementById('docType').value,
        clientName: document.getElementById('clientName').value.trim() || null,
        issueDate: document.getElementById('issueDate').value,
        expiryDate: document.getElementById('expiryDate').value || null,
        notes: document.getElementById('notes').value.trim() || null
    };
    
    try {
        window.Database.addDocument(document);
        alert('Document created successfully!');
        document.getElementById('addDocumentForm').reset();
        showPage('documents');
        loadDocuments();
    } catch (error) {
        alert('Error: ' + error.message);
    }
}

function editDocument(id) {
    const doc = window.Database.getDocuments().find(d => d.id === id);
    if (!doc) return;
    
    const modal = document.getElementById('documentModal');
    const modalBody = document.querySelector('.modal-body');
    document.getElementById('modalTitle').textContent = 'Edit Document';
    
    modalBody.innerHTML = `
        <form id="editForm">
            <div class="form-group">
                <label>Reference Number</label>
                <input type="text" value="${window.Database.escapeHtml(doc.referenceNumber)}" readonly>
            </div>
            <div class="form-group">
                <label>Document Type</label>
                <select id="editDocType" required>
                    <option value="Quotation" ${doc.documentType === 'Quotation' ? 'selected' : ''}>Quotation</option>
                    <option value="Invoice" ${doc.documentType === 'Invoice' ? 'selected' : ''}>Invoice</option>
                    <option value="Delivery Note" ${doc.documentType === 'Delivery Note' ? 'selected' : ''}>Delivery Note</option>
                    <option value="Contract" ${doc.documentType === 'Contract' ? 'selected' : ''}>Contract</option>
                    <option value="Certificate" ${doc.documentType === 'Certificate' ? 'selected' : ''}>Certificate</option>
                    <option value="Letter" ${doc.documentType === 'Letter' ? 'selected' : ''}>Letter</option>
                    <option value="Other" ${doc.documentType === 'Other' ? 'selected' : ''}>Other</option>
                </select>
            </div>
            <div class="form-group">
                <label>Client Name</label>
                <input type="text" id="editClientName" value="${window.Database.escapeHtml(doc.clientName || '')}">
            </div>
            <div class="form-group">
                <label>Issue Date</label>
                <input type="date" id="editIssueDate" value="${doc.issueDate}" required>
            </div>
            <div class="form-group">
                <label>Expiry Date</label>
                <input type="date" id="editExpiryDate" value="${doc.expiryDate || ''}">
            </div>
            <div class="form-actions">
                <button type="submit" class="submit-btn">Save Changes</button>
                <button type="button" class="cancel-btn" onclick="closeModal()">Cancel</button>
            </div>
        </form>
    `;
    
    document.getElementById('editForm').addEventListener('submit', function(e) {
        e.preventDefault();
        
        window.Database.updateDocument(id, {
            documentType: document.getElementById('editDocType').value,
            clientName: document.getElementById('editClientName').value.trim(),
            issueDate: document.getElementById('editIssueDate').value,
            expiryDate: document.getElementById('editExpiryDate').value || null
        });
        
        alert('Document updated successfully!');
        closeModal();
        loadDocuments();
    });
    
    modal.style.display = 'flex';
}

function revokeDocument(id) {
    const doc = window.Database.getDocuments().find(d => d.id === id);
    if (!doc) return;
    
    const reason = prompt('Enter revocation reason:', 'Revoked by administrator');
    if (reason === null) return;
    
    window.Database.updateDocument(id, {
        status: 'revoked',
        revocationReason: reason || 'No reason provided'
    });
    
    alert('Document revoked successfully!');
    loadDocuments();
}

function deleteDocument(id) {
    if (!confirm('Are you sure you want to delete this document? This action cannot be undone.')) {
        return;
    }
    
    window.Database.deleteDocument(id);
    alert('Document deleted successfully!');
    loadDocuments();
}

function loadHistory() {
    const search = document.getElementById('historySearch')?.value || '';
    let logs = window.Database.getVerificationLogs();
    
    if (search) {
        const searchTerm = search.toLowerCase();
        logs = logs.filter(log => 
            log.referenceNumber.toLowerCase().includes(searchTerm)
        );
    }
    
    const tbody = document.querySelector('#historyTable tbody');
    tbody.innerHTML = logs.slice(0, 100).map(log => `
        <tr>
            <td>${window.Database.escapeHtml(log.referenceNumber)}</td>
            <td>${window.Database.escapeHtml(log.documentType || 'Unknown')}</td>
            <td>${window.Database.escapeHtml(log.clientName || 'N/A')}</td>
            <td><span class="status-badge ${log.status}">${log.status}</span></td>
            <td>${window.Database.escapeHtml(log.browserType || 'Unknown')}</td>
            <td>${window.Database.formatDate(log.timestamp)}</td>
        </tr>
    `).join('');
}

function showPage(pageName) {
    // Update nav items
    document.querySelectorAll('.nav-item').forEach(item => {
        item.classList.toggle('active', item.dataset.page === pageName);
    });
    
    // Show/hide pages
    document.querySelectorAll('.page').forEach(page => {
        page.classList.toggle('active', page.id === pageName + 'Page');
    });
}

function closeModal() {
    document.getElementById('documentModal').style.display = 'none';
}

function debounce(func, wait) {
    let timeout;
    return function executedFunction(...args) {
        const later = () => {
            clearTimeout(timeout);
            func(...args);
        };
        clearTimeout(timeout);
        timeout = setTimeout(later, wait);
    };
}

