<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Verify the authenticity of Green Transport & Logistics documents">
    <meta name="keywords" content="document verification, QR code, Green Transport, logistics, authentication">
    <title>Document Verification | Green Transport & Logistics</title>
    <link rel="stylesheet" href="css/styles.css">
    <link rel="icon" type="image/x-icon" href="assets/favicon.ico">
</head>
<body>
    <div class="container">
        <!-- Header -->
        <header class="header">
            <div class="logo">
                <img src="images/logo.png" alt="Green Transport & Logistics Logo" onerror="this.style.display='none'">
                <h1>Green Transport & Logistics</h1>
            </div>
            <h2>Document Verification</h2>
            <p class="subtitle">Verify the authenticity of any official Green Transport & Logistics document</p>
        </header>

        <!-- Search Section -->
        <section class="search-section">
            <div class="search-box">
                <label for="referenceInput">Enter Document Reference Number</label>
                <input 
                    type="text" 
                    id="referenceInput" 
                    placeholder="Example: GTL-QT-2026-00125"
                    maxlength="50"
                    autocomplete="off"
                    aria-label="Document reference number"
                >
                <button id="verifyBtn" class="verify-btn">
                    <span class="btn-text">Verify Document</span>
                    <span class="btn-loader" style="display:none;">Verifying...</span>
                </button>
            </div>
        </section>

        <!-- Results Section -->
        <section id="resultsSection" class="results-section" style="display:none;" aria-live="polite">
            <!-- Verified Result -->
            <div id="verifiedCard" class="result-card verified" style="display:none;">
                <div class="status-icon">✅</div>
                <h3 class="status-title">VERIFIED</h3>
                <div class="details-grid">
                    <div class="detail-item">
                        <span class="label">Document Type:</span>
                        <span class="value" id="docType"></span>
                    </div>
                    <div class="detail-item">
                        <span class="label">Reference Number:</span>
                        <span class="value" id="docRef"></span>
                    </div>
                    <div class="detail-item">
                        <span class="label">Issue Date:</span>
                        <span class="value" id="docIssue"></span>
                    </div>
                    <div class="detail-item">
                        <span class="label">Expiry Date:</span>
                        <span class="value" id="docExpiry"></span>
                    </div>
                    <div class="detail-item">
                        <span class="label">Issued By:</span>
                        <span class="value" id="docIssuedBy"></span>
                    </div>
                    <div class="detail-item">
                        <span class="label">Client Name:</span>
                        <span class="value" id="docClient"></span>
                    </div>
                    <div class="detail-item">
                        <span class="label">Status:</span>
                        <span class="value status-badge" id="docStatus"></span>
                    </div>
                    <div class="detail-item">
                        <span class="label">QR Generated On:</span>
                        <span class="value" id="docQrDate"></span>
                    </div>
                    <div class="detail-item">
                        <span class="label">Last Updated:</span>
                        <span class="value" id="docUpdated"></span>
                    </div>
                </div>
            </div>

            <!-- Revoked Result -->
            <div id="revokedCard" class="result-card revoked" style="display:none;">
                <div class="status-icon">⚠️</div>
                <h3 class="status-title">Document Revoked</h3>
                <p class="revocation-reason" id="revocationReason"></p>
                <p class="contact-info">
                    This document has been invalidated. For more information, please contact Green Transport & Logistics.
                </p>
            </div>

            <!-- Invalid Result -->
            <div id="invalidCard" class="result-card invalid" style="display:none;">
                <div class="status-icon">❌</div>
                <h3 class="status-title">INVALID DOCUMENT</h3>
                <p class="error-message">The document reference could not be found in our records.</p>
                <p class="contact-info">
                    If you believe this is an error, please contact Green Transport & Logistics:
                </p>
                <div class="contact-details">
                    <p>📞 +234-XXX-XXX-XXXX</p>
                    <p>📧 info@greenlogistics-ng.com</p>
                </div>
                <button class="contact-btn" onclick="window.location.href='mailto:info@greenlogistics-ng.com'">
                    Contact Us
                </button>
            </div>

            <!-- Error Result -->
            <div id="errorCard" class="result-card error" style="display:none;">
                <div class="status-icon">⚠️</div>
                <h3 class="status-title">Verification Error</h3>
                <p class="error-message" id="errorMessage"></p>
                <button class="retry-btn" onclick="resetSearch()">Try Again</button>
            </div>
        </section>

        <!-- Footer -->
        <footer class="footer">
            <p>&copy; 2026 Green Transport & Logistics. All rights reserved.</p>
            <p class="security-note">🔒 Secure verification powered by encrypted document authentication</p>
            <p class="demo-note" style="display:none;">⚠️ Demo Mode: Using client-side storage. Connect to backend API for production.</p>
        </footer>
    </div>

    <script src="js/database.js"></script>
    <script src="js/script.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | Green Transport & Logistics</title>
    <link rel="stylesheet" href="css/admin.css">
    <link rel="icon" type="image/x-icon" href="assets/favicon.ico">
</head>
<body>
    <!-- Login Page -->
    <div id="loginPage" class="login-container">
        <div class="login-box">
            <div class="logo">
                <img src="images/logo.png" alt="Logo" onerror="this.style.display='none'">
                <h1>Admin Dashboard</h1>
            </div>
            <form id="loginForm">
                <div class="form-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" required autocomplete="username">
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" required autocomplete="current-password">
                </div>
                <button type="submit" class="login-btn">Login</button>
                <p id="loginError" class="error-message" style="display:none;"></p>
            </form>
        </div>
    </div>

    <!-- Main Dashboard -->
    <div id="dashboardPage" class="dashboard-container" style="display:none;">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>Green Transport</h2>
                <p>Admin Dashboard</p>
            </div>
            <nav class="sidebar-nav">
                <a href="#" class="nav-item active" data-page="overview">
                    <span class="nav-icon">📊</span>
                    Overview
                </a>
                <a href="#" class="nav-item" data-page="documents">
                    <span class="nav-icon">📄</span>
                    Documents
                </a>
                <a href="#" class="nav-item" data-page="add">
                    <span class="nav-icon">➕</span>
                    Add Document
                </a>
                <a href="#" class="nav-item" data-page="history">
                    <span class="nav-icon">📜</span>
                    Verification History
                </a>
            </nav>
            <div class="sidebar-footer">
                <div class="user-info">
                    <span id="userFullName">Admin User</span>
                    <span id="userRole" class="role-badge">Admin</span>
                </div>
                <button id="logoutBtn" class="logout-btn">Logout</button>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Overview Page -->
            <div id="overviewPage" class="page active">
                <header class="page-header">
                    <h1>Dashboard Overview</h1>
                </header>
                
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon">📄</div>
                        <div class="stat-info">
                            <h3 id="totalDocuments">0</h3>
                            <p>Total Documents</p>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon">✅</div>
                        <div class="stat-info">
                            <h3 id="totalVerifications">0</h3>
                            <p>Total Verifications</p>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon">❌</div>
                        <div class="stat-info">
                            <h3 id="invalidAttempts">0</h3>
                            <p>Invalid Attempts</p>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon">📈</div>
                        <div class="stat-info">
                            <h3 id="successRate">0%</h3>
                            <p>Success Rate</p>
                        </div>
                    </div>
                </div>

                <div class="recent-verifications">
                    <h2>Recent Verifications</h2>
                    <div class="table-container">
                        <table id="recentTable">
                            <thead>
                                <tr>
                                    <th>Reference</th>
                                    <th>Type</th>
                                    <th>Status</th>
                                    <th>Time</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Dynamic content -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Documents Page -->
            <div id="documentsPage" class="page">
                <header class="page-header">
                    <h1>Manage Documents</h1>
                    <button class="add-btn" onclick="showPage('add')">+ Add Document</button>
                </header>
                
                <div class="filters">
                    <input type="text" id="searchInput" placeholder="Search documents..." class="search-input">
                    <select id="statusFilter" class="filter-select">
                        <option value="">All Statuses</option>
                        <option value="valid">Valid</option>
                        <option value="expired">Expired</option>
                        <option value="revoked">Revoked</option>
                    </select>
                </div>

                <div class="table-container">
                    <table id="documentsTable">
                        <thead>
                            <tr>
                                <th>Reference</th>
                                <th>Type</th>
                                <th>Client</th>
                                <th>Issue Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Dynamic content -->
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Add Document Page -->
            <div id="addPage" class="page">
                <header class="page-header">
                    <h1>Add New Document</h1>
                </header>
                
                <form id="addDocumentForm" class="document-form">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="refNumber">Reference Number *</label>
                            <input type="text" id="refNumber" required placeholder="GTL-QT-2026-00125">
                        </div>
                        <div class="form-group">
                            <label for="docType">Document Type *</label>
                            <select id="docType" required>
                                <option value="">Select type</option>
                                <option value="Quotation">Quotation</option>
                                <option value="Invoice">Invoice</option>
                                <option value="Delivery Note">Delivery Note</option>
                                <option value="Contract">Contract</option>
                                <option value="Certificate">Certificate</option>
                                <option value="Letter">Letter</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="clientName">Client Name</label>
                            <input type="text" id="clientName" placeholder="Optional">
                        </div>
                        <div class="form-group">
                            <label for="issueDate">Issue Date *</label>
                            <input type="date" id="issueDate" required>
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="expiryDate">Expiry Date</label>
                            <input type="date" id="expiryDate">
                        </div>
                        <div class="form-group">
                            <label for="notes">Notes</label>
                            <input type="text" id="notes" placeholder="Optional notes">
                        </div>
                    </div>
                    
                    <div class="form-actions">
                        <button type="submit" class="submit-btn">Create Document</button>
                        <button type="button" class="cancel-btn" onclick="showPage('documents')">Cancel</button>
                    </div>
                </form>
            </div>

            <!-- History Page -->
            <div id="historyPage" class="page">
                <header class="page-header">
                    <h1>Verification History</h1>
                </header>
                
                <div class="filters">
                    <input type="text" id="historySearch" placeholder="Search history..." class="search-input">
                </div>

                <div class="table-container">
                    <table id="historyTable">
                        <thead>
                            <tr>
                                <th>Reference</th>
                                <th>Type</th>
                                <th>Client</th>
                                <th>Status</th>
                                <th>Time</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Dynamic content -->
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <!-- Modal for Edit/Revoke -->
    <div id="documentModal" class="modal" style="display:none;">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="modalTitle">Edit Document</h2>
                <button class="close-modal" onclick="closeModal()">&times;</button>
            </div>
            <div class="modal-body">
                <!-- Dynamic content -->
            </div>
        </div>
    </div>

    <script src="js/database.js"></script>
    <script src="js/admin.js"></script>
</body>
</html>

:root {
    --primary-green: #2E7D32;
    --dark-green: #1B5E20;
    --light-green: #4CAF50;
    --success-green: #66BB6A;
    --error-red: #D32F2F;
    --warning-orange: #F57C00;
    --text-dark: #212121;
    --text-light: #757575;
    --bg-light: #F5F5F5;
    --white: #FFFFFF;
    --shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    --shadow-lg: 0 10px 20px rgba(0, 0, 0, 0.15);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
    min-height: 100vh;
    color: var(--text-dark);
    line-height: 1.6;
}

.container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

/* Header */
.header {
    text-align: center;
    margin-bottom: 2rem;
    padding: 2rem;
    background: var(--white);
    border-radius: 12px;
    box-shadow: var(--shadow);
}

.logo {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1rem;
}

.logo img {
    height: 60px;
    width: auto;
}

.logo h1 {
    color: var(--primary-green);
    font-size: 1.8rem;
    font-weight: 700;
}

.header h2 {
    color: var(--dark-green);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
}

.subtitle {
    color: var(--text-light);
    font-size: 1rem;
}

/* Search Section */
.search-section {
    background: var(--white);
    padding: 2rem;
    border-radius: 12px;
    box-shadow: var(--shadow);
    margin-bottom: 2rem;
}

.search-box {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.search-box label {
    font-weight: 600;
    color: var(--text-dark);
    font-size: 1rem;
}

.search-box input {
    padding: 1rem;
    border: 2px solid #E0E0E0;
    border-radius: 8px;
    font-size: 1rem;
    transition: all 0.3s ease;
}

.search-box input:focus {
    outline: none;
    border-color: var(--primary-green);
    box-shadow: 0 0 0 3px rgba(46, 125, 50, 0.1);
}

.verify-btn {
    background: var(--primary-green);
    color: var(--white);
    border: none;
    padding: 1rem 2rem;
    border-radius: 8px;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
}

.verify-btn:hover {
    background: var(--dark-green);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.verify-btn:active {
    transform: translateY(0);
}

.verify-btn:disabled {
    background: #9E9E9E;
    cursor: not-allowed;
    transform: none;
}

/* Results Section */
.results-section {
    flex: 1;
}

.result-card {
    background: var(--white);
    padding: 2rem;
    border-radius: 12px;
    box-shadow: var(--shadow);
    text-align: center;
    animation: fadeIn 0.5s ease;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

.result-card.verified {
    border-left: 5px solid var(--success-green);
}

.result-card.revoked {
    border-left: 5px solid var(--warning-orange);
}

.result-card.invalid {
    border-left: 5px solid var(--error-red);
}

.result-card.error {
    border-left: 5px solid var(--error-red);
}

.status-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
}

.status-title {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--dark-green);
}

.result-card.verified .status-title {
    color: var(--success-green);
}

.result-card.revoked .status-title {
    color: var(--warning-orange);
}

.result-card.invalid .status-title,
.result-card.error .status-title {
    color: var(--error-red);
}

/* Details Grid */
.details-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    text-align: left;
    margin-top: 1.5rem;
}

.detail-item {
    padding: 0.75rem;
    background: var(--bg-light);
    border-radius: 6px;
}

.detail-item .label {
    font-weight: 600;
    color: var(--text-light);
    font-size: 0.85rem;
    display: block;
    margin-bottom: 0.25rem;
}

.detail-item .value {
    color: var(--text-dark);
    font-size: 1rem;
    font-weight: 500;
}

.status-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
}

.status-badge.valid {
    background: #E8F5E9;
    color: var(--success-green);
}

.status-badge.expired {
    background: #FFF3E0;
    color: var(--warning-orange);
}

.status-badge.revoked {
    background: #FFEBEE;
    color: var(--error-red);
}

/* Contact Info */
.contact-info {
    color: var(--text-light);
    margin: 1rem 0;
    font-size: 0.95rem;
}

.contact-details {
    background: var(--bg-light);
    padding: 1rem;
    border-radius: 8px;
    margin: 1.5rem 0;
}

.contact-details p {
    margin: 0.5rem 0;
    color: var(--text-dark);
}

.contact-btn,
.retry-btn {
    background: var(--primary-green);
    color: var(--white);
    border: none;
    padding: 0.75rem 2rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 1rem;
}

.contact-btn:hover,
.retry-btn:hover {
    background: var(--dark-green);
    transform: translateY(-2px);
}

.revocation-reason {
    background: #FFF3E0;
    padding: 1rem;
    border-radius: 8px;
    color: var(--warning-orange);
    font-weight: 500;
    margin: 1rem 0;
}

.error-message {
    color: var(--text-light);
    margin: 1rem 0;
}

/* Footer */
.footer {
    text-align: center;
    padding: 2rem;
    margin-top: 2rem;
    color: var(--text-light);
    font-size: 0.9rem;
}

.security-note {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--primary-green);
}

.demo-note {
    background: #FFF3E0;
    padding: 0.75rem;
    border-radius: 6px;
    margin-top: 1rem;
    color: var(--warning-orange);
    font-weight: 600;
}

/* Mobile Responsive */
@media (max-width: 600px) {
    .container {
        padding: 1rem 0.5rem;
    }
    
    .header {
        padding: 1.5rem 1rem;
    }
    
    .logo h1 {
        font-size: 1.4rem;
    }
    
    .header h2 {
        font-size: 1.3rem;
    }
    
    .search-section {
        padding: 1.5rem 1rem;
    }
    
    .result-card {
        padding: 1.5rem 1rem;
    }
    
    .details-grid {
        grid-template-columns: 1fr;
    }
    
    .status-icon {
        font-size: 3rem;
    }
    
    .status-title {
        font-size: 1.5rem;
    }
}

/* Loading Animation */
.btn-loader {
    display: inline-block;
    animation: pulse 1.5s infinite;
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}

/* Accessibility */
@media (prefers-reduced-motion: reduce) {
    * {
        animation: none !important;
        transition: none !important;
    }
}

/* Focus States */
input:focus,
button:focus {
    outline: 3px solid var(--primary-green);
    outline-offset: 2px;
}

/* High Contrast Mode */
@media (prefers-contrast: high) {
    :root {
        --primary-green: #006400;
        --dark-green: #004D00;
        --success-green: #008000;
    }
    
    .result-card {
        border: 3px solid var(--text-dark);
    }
}

